{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/wiki-reread.sh\"", "async": false }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/source-truth-lint.sh\"", "async": false }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/wiki-capture-suggest.sh\"", "async": false },
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/source-truth-lint.sh\"", "async": false }
        ]
      }
    ]
  }
}
