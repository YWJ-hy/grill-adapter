{
  "name": "@grill-adapter/obsidian-wiki",
  "version": "0.1.0",
  "description": "Bound Obsidian Wiki MCP server and local runtime CLI for grill-adapter.",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "obsidian-wiki": "dist/index.js",
    "obsidian-wiki-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js",
    "prepublishOnly": "npm run typecheck && npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "npm run build && vitest run --testTimeout 30000"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "esbuild": "^0.28.1",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
