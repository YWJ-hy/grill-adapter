{
  "name": "grill-adapter",
  "version": "0.1.0",
  "description": "Host-agnostic Claude Code adapter that adds sectioned/cross-repo project wiki (Disclose/Carry/Bind/Capture), Lanhu requirements intake, and source-of-truth verify/lint as standalone skills + hooks — no host skill is ever patched. Defaults to grill (mattpocock/skills) as the front-end; also runs on plain Claude Code.",
  "defaultHost": "grill",
  "generatedMarker": "Generated by grill-adapter",
  "hookMarker": "grill-adapter/hooks/",
  "userLevel": {
    "payload": ["scripts", "contracts", "hooks", "mcp"],
    "skills": [
      "wiki-research",
      "wiki-materialize",
      "update-wiki",
      "init-wiki",
      "import-wiki",
      "migrate-wiki",
      "publish-shared-wiki",
      "shared-wiki-mcp",
      "scaffold-practice-skill",
      "lanhu-requirements",
      "break-loop",
      "source-truth-check"
    ],
    "agents": [
      "wiki-researcher.md",
      "lanhu-frontend-requirements-analyst.md",
      "lanhu-backend-requirements-analyst.md"
    ]
  },
  "projectLevel": {
    "hookSettings": "host-adapters/hooks.settings.json",
    "hostConventions": {
      "grill": "host-adapters/grill/CLAUDE.md",
      "plain": "host-adapters/plain/CLAUDE.md"
    }
  },
  "buildSteps": {
    "rolePrdSync": "lib/sync_role_prd.py",
    "sharedWikiMcp": "mcp/shared-wiki"
  },
  "removedPaths": []
}
