{
  // Generated by grill-adapter.
  // AI-facing authoring contract for .adapter/context/<feature-slug>.ticket-roster.json.
  //
  // WHAT THIS IS: the host-agnostic boundary between whatever tracker a host uses and grill-adapter's
  // Carry/Bind engine. The engine never reads a tracker, a plan document, or the network -- it
  // fingerprints exactly the ticket text this file hands it. Your host's convention block in the
  // project CLAUDE.md tells you how to fill it:
  //
  //   grill, local-markdown tracker -> one entry per `.scratch/<feature-slug>/issues/<NN>-<slug>.md`;
  //                                    taskId is the NN prefix, text is the whole file body.
  //   grill, GitHub/Linear tracker  -> one entry per ticket issue (`gh issue view <n> --json body,title`);
  //                                    taskId is the issue number, text is the issue body.
  //   plain Claude Code             -> whatever the user points you at; taskId is any stable id.
  //   direct tracker implementation -> exactly one entry; wiki_readiness.py prepare-issue copies the
  //                                    real issue id/title and full body without rewriting it.
  //   confirmed conversational work -> exactly one `manual` entry; the complete confirmed brief is
  //                                    the fingerprint input and must not be silently split.
  //
  // Which form applies is recorded per repo by grill's `/setup-matt-pocock-skills` in
  // docs/agents/issue-tracker.md. Read that, do not guess.
  //
  // WHY IT EXISTS: hosts disagree about where tickets live and some (grill on a real tracker) produce
  // no local plan file at all, so there is no single document the engine could parse. Handing the
  // engine a roster keeps it host-agnostic: a new host needs a convention block, never an engine change.
  //
  // LIFECYCLE: transient. It is an input to --scaffold-tasks / --bind-fingerprints / --finalize /
  // --fingerprint-preflight, never a deliverable. Nothing under .adapter/context/ is committed.
  // Regenerate it from the tracker whenever tickets change, then re-run --finalize: the fingerprints
  // are what detect ticket drift between planning and execution.

  // Feature identity. Must match the <feature-slug> in the sidecar filenames and the sidecar's
  // featureSlug field, so a project working on several features at once keeps them separate.
  "featureSlug": "example-feature",

  // Where these tickets came from. Audit metadata only -- recorded into the sidecar, never branched on.
  // One of: "grill-local-scratch" | "github-issues" | "manual".
  "ticketSource": "grill-local-scratch",

  // One entry per ticket, in dependency order (blockers first) to mirror the host's own ordering.
  // Every field is required; the engine rejects a roster with an empty tickets array.
  "tickets": [
    {
      // Stable id, unique within the roster. It is what destination.tasks in the sidecar routes to,
      // and what `/wiki-materialize <ticket-id>` is called with at execution time. Keep it exactly as
      // the host names it (grill local: the NN prefix; a real tracker: the issue number).
      "taskId": "01",
      "taskTitle": "Implement path-based form updates",
      // The full ticket text, verbatim. This is the fingerprint input: sha256 of the normalized text
      // is stamped into the sidecar's taskWikiRefs, so execution can detect that a ticket changed
      // after the wiki sections were bound to it. Do not summarize, reorder, or strip it -- a rewritten
      // body silently changes the digest and reads as drift.
      "text": "# 01 — Implement path-based form updates\n\n**What to build:** field writes go through updateByPath(path, value).\n\n**Blocked by:** None — can start immediately."
    },
    {
      "taskId": "02",
      "taskTitle": "Add contract coverage",
      "text": "# 02 — Add contract coverage\n\n**What to build:** cover the shared payload contract.\n\n**Blocked by:** 01"
    }
  ]
}
